generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id          String   @id @default(uuid())
  title       String
  director    String
  genre       String
  releaseYear Int
  rating      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
